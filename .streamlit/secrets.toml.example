# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Cloud, paste these key-value pairs in
# App Settings → Secrets (do NOT commit secrets.toml to git).

GROQ_API_KEY = "gsk_your_key_here"
GROQ_MODEL   = "llama-3.3-70b-versatile"

# Optional — defaults are set automatically if omitted
# VECTOR_STORE_DIR      = "data/vector_store"
# RESUME_DIR            = "data/resumes"
# REPORTS_DIR           = "reports"
# CHROMA_COLLECTION_NAME = "resumes"
# EMBEDDING_MODEL       = "sentence-transformers/all-MiniLM-L6-v2"
